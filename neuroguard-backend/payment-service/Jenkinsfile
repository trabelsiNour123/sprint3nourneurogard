pipeline {
    agent any

    tools {
        jdk 'JDK17'
        maven 'Maven3'
    }

    environment {
        SERVICE_DIR = 'neuroguard-backend/payment-service'
        DOCKER_IMAGE = 'neuroguard/payment-service'
        VERSION = "1.0.${env.BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build & Test') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh 'chmod +x mvnw'
                    sh './mvnw clean test -Ptest -Dspring.profiles.active=test'
                }
            }
            post {
                always {
                    junit '**/target/surefire-reports/*.xml'
                }
            }
        }

        stage('Package') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh './mvnw package -DskipTests'
                }
            }
            post {
                success {
                    archiveArtifacts "${SERVICE_DIR}/target/*.jar"
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh "docker build -t ${DOCKER_IMAGE}:${VERSION} ."
                    sh "docker tag ${DOCKER_IMAGE}:${VERSION} ${DOCKER_IMAGE}:latest"
                }
            }
        }
    }

    post {
        always {
            // Avoid destructive global prune on shared agents. Keep local cleanup minimal.
            sh 'docker image prune -f || true'
        }
        success {
            echo "Pipeline SUCCESS: ${env.JOB_NAME} - ${env.BUILD_NUMBER}"
        }
        failure {
            echo "Pipeline FAILED: ${env.JOB_NAME} - ${env.BUILD_NUMBER}"
        }
    }
}