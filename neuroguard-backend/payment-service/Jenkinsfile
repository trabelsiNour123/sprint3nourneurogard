pipeline {
    agent any

    // Using the project's Maven Wrapper (`./mvnw`) and the system Java installed on the agent.
    // Remove `tools` requirement so the pipeline won't fail when named tool installations
    // (like 'JDK17' or 'Maven3') are not configured in the Jenkins controller.

    environment {
        SERVICE_DIR = 'neuroguard-backend/payment-service'
        DOCKER_IMAGE = 'neuroguard/payment-service'
        VERSION = "1.0.${env.BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build & Test') {
            steps {
                dir("${SERVICE_DIR}") {
                    // ensure mvnw is executable and run in one shell so env exports apply
                                        sh '''#!/bin/sh
                                        set -euo pipefail
                                        chmod +x mvnw
                                        # detect java major version
                                        if [ -x "$(command -v java)" ]; then
                                            JAVA_VER_STR=$(java -version 2>&1 | head -n1 || true)
                                            echo "agent java: $JAVA_VER_STR"
                                            JAVA_MAJOR=$(printf "%s" "$JAVA_VER_STR" | sed -E 's/.*version \"([0-9]+).*/\1/' || true)
                                        else
                                            JAVA_MAJOR=0
                                        fi
                                        # if agent Java is newer than 17 (e.g., 21) download a portable Temurin 17 and use it
                                        if [ "${JAVA_MAJOR:-0}" -gt 17 ]; then
                                            echo "Agent java major=${JAVA_MAJOR} >17; installing portable JDK17"
                                            JDK_DIR="/tmp/jdk17"
                                            mkdir -p "$JDK_DIR"
                                            curl -sSL -o /tmp/jdk17.tar.gz https://github.com/adoptium/temurin17-binaries/releases/latest/download/OpenJDK17U-jdk_x64_linux_hotspot.tar.gz
                                            tar -xzf /tmp/jdk17.tar.gz -C /tmp
                                            # find extracted dir
                                            EXTRACTED=$(find /tmp -maxdepth 1 -type d -name 'jdk-*' | head -n1 || true)
                                            if [ -d "$EXTRACTED" ]; then
                                                export JAVA_HOME="$EXTRACTED"
                                                export PATH="$JAVA_HOME/bin:$PATH"
                                                echo "Using downloaded JAVA_HOME=$JAVA_HOME"
                                            else
                                                echo "Failed to extract JDK, continuing with agent java"
                                            fi
                                        else
                                            if [ -x "$(command -v java)" ]; then
                                                JAVA_BIN=$(command -v java)
                                                JAVA_HOME=$(dirname $(dirname $(readlink -f "$JAVA_BIN"))) || true
                                                echo "Detected JAVA_HOME=${JAVA_HOME}"
                                                export JAVA_HOME
                                                export PATH="$JAVA_HOME/bin:$PATH"
                                            else
                                                echo "java not found on PATH; mvnw will use default java in shell"
                                            fi
                                        fi
                                        # run tests (removed -Ptest which doesn't exist)
                                        ./mvnw clean test -Dspring.profiles.active=test
                                        '''
                }
            }
            post {
                always {
                    junit testResults: '**/target/surefire-reports/*.xml', allowEmptyResults: true
                }
            }
        }

        stage('Package') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh './mvnw package -DskipTests'
                }
            }
            post {
                success {
                    archiveArtifacts "${SERVICE_DIR}/target/*.jar"
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh "docker build -t ${DOCKER_IMAGE}:${VERSION} ."
                    sh "docker tag ${DOCKER_IMAGE}:${VERSION} ${DOCKER_IMAGE}:latest"
                }
            }
        }
    }

    post {
        always {
            // Avoid failing if Docker is not available on the agent (e.g., no docker socket).
            sh 'if docker info >/dev/null 2>&1; then docker image prune -f; else echo "docker not available"; fi || true'
        }
        success {
            echo "Pipeline SUCCESS: ${env.JOB_NAME} - ${env.BUILD_NUMBER}"
        }
        failure {
            echo "Pipeline FAILED: ${env.JOB_NAME} - ${env.BUILD_NUMBER}"
        }
    }
}