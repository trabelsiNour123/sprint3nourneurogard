pipeline {
    agent any

    tools {
        jdk 'JDK17'
        maven 'Maven3'
    }

    environment {
        SERVICE_DIR = 'neuroguard-backend/payment-service'
        DOCKER_IMAGE = 'neuroguard/payment-service'
        VERSION = "1.0.${env.BUILD_NUMBER}"
        MAVEN_OPTS = '-Dmaven.repo.local=$WORKSPACE/.m2/repository'
        
        // Variables pour les tests
        TEST_DB_CONTAINER = 'payment-service-test-db'
        TEST_DB_PASSWORD = 'test123'
    }

    options {
        disableConcurrentBuilds()
        timestamps()
        timeout(time: 45, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10', artifactNumToKeepStr: '5'))
        skipDefaultCheckout()
    }

    stages {
        stage('Checkout') {
            steps {
                echo '📦 Checking out source code...'
                checkout scm
            }
        }

        stage('Setup & Cache') {
            steps {
                echo '🔄 Setting up build environment...'
                script {
                    // Create Maven cache directory
                    sh 'mkdir -p $WORKSPACE/.m2/repository'
                    
                    // Cache Docker layers
                    sh 'docker system prune -f || true'
                }
            }
        }

        stage('Build & Compile') {
            steps {
                dir("${SERVICE_DIR}") {
                    echo '🔨 Building payment-service...'
                    script {
                        if (isUnix()) {
                            sh 'chmod +x mvnw'
                            sh './mvnw clean compile -U -Dmaven.test.skip=true'
                        } else {
                            bat 'mvnw.cmd clean compile -Dmaven.test.skip=true'
                        }
                    }
                }
            }
        }

        stage('Unit Tests') {
            steps {
                dir("${SERVICE_DIR}") {
                    echo '🧪 Running unit tests...'
                    script {
                        // Use test profile to avoid database issues
                        if (isUnix()) {
                            sh './mvnw test -Ptest -Dspring.profiles.active=test'
                        } else {
                            bat 'mvnw.cmd test -Ptest -Dspring.profiles.active=test'
                        }
                    }
                }
            }
            post {
                always {
                    junit allowEmptyResults: false,
                          testResults: '**/target/surefire-reports/*.xml'
                    
                    // Archive test reports
                    archiveArtifacts artifacts: '**/target/surefire-reports/*.xml',
                              allowEmptyArchive: true
                }
            }
        }

        stage('Start Test Database') {
            when {
                expression { isUnix() }
            }
            steps {
                echo '🐘 Starting PostgreSQL test container...'
                script {
                    sh """
                        docker rm -f ${TEST_DB_CONTAINER} || true
                        docker run -d \
                            --name ${TEST_DB_CONTAINER} \
                            -e POSTGRES_DB=payment_test \
                            -e POSTGRES_USER=test_user \
                            -e POSTGRES_PASSWORD=${TEST_DB_PASSWORD} \
                            -p 5432:5432 \
                            postgres:15-alpine
                        
                        # Wait for PostgreSQL to be ready
                        for i in {1..30}; do
                            if docker exec ${TEST_DB_CONTAINER} pg_isready -U test_user; then
                                echo "✅ PostgreSQL is ready"
                                break
                            fi
                            sleep 2
                        done
                    """
                }
            }
        }

        stage('Integration Tests') {
            dependsOn 'Start Test Database'
            steps {
                dir("${SERVICE_DIR}") {
                    echo '🔗 Running integration tests...'
                    script {
                        if (isUnix()) {
                            sh """
                                ./mvnw verify -Pintegration-test \
                                    -Dspring.profiles.active=integration \
                                    -Dtest.db.host=localhost \
                                    -Dtest.db.port=5432 \
                                    -Dtest.db.name=payment_test \
                                    -Dtest.db.user=test_user \
                                    -Dtest.db.password=${TEST_DB_PASSWORD}
                            """
                        } else {
                            bat """
                                mvnw.cmd verify -Pintegration-test \
                                    -Dspring.profiles.active=integration \
                                    -Dtest.db.host=localhost \
                                    -Dtest.db.port=5432 \
                                    -Dtest.db.name=payment_test \
                                    -Dtest.db.user=test_user \
                                    -Dtest.db.password=${TEST_DB_PASSWORD}
                            """
                        }
                    }
                }
            }
            post {
                always {
                    junit testResults: '**/target/failsafe-reports/*.xml',
                          allowEmptyResults: true
                    
                    // Cleanup test container
                    sh "docker rm -f ${TEST_DB_CONTAINER} || true"
                }
            }
        }

        stage('Package Application') {
            steps {
                dir("${SERVICE_DIR}") {
                    echo '📦 Packaging application...'
                    script {
                        if (isUnix()) {
                            sh './mvnw package -DskipTests'
                        } else {
                            bat 'mvnw.cmd package -DskipTests'
                        }
                    }
                }
            }
            post {
                success {
                    archiveArtifacts artifacts: "${SERVICE_DIR}/target/*.jar",
                                  fingerprint: true
                }
            }
        }

        stage('Security Scan') {
            steps {
                dir("${SERVICE_DIR}") {
                    echo '🔒 Running security scan...'
                    script {
                        if (isUnix()) {
                            sh """
                                ./mvnw org.owasp:dependency-check-maven:check \
                                    -Dformat=HTML \
                                    -Dformat=XML
                            """
                        } else {
                            bat """
                                mvnw.cmd org.owasp:dependency-check-maven:check \
                                    -Dformat=HTML \
                                    -Dformat=XML
                            """
                        }
                    }
                }
            }
            post {
                always {
                    dependencyCheckPublisher pattern: '**/target/dependency-check-report.xml'
                    publishHTML([
                        allowMissing: true,
                        alwaysLinkToLastBuild: true,
                        keepAll: true,
                        reportDir: "${SERVICE_DIR}/target",
                        reportFiles: 'dependency-check-report.html',
                        reportName: 'Security Scan Report'
                    ])
                }
            }
        }

        stage('Code Coverage') {
            steps {
                dir("${SERVICE_DIR}") {
                    echo '📊 Generating code coverage report...'
                    script {
                        if (isUnix()) {
                            sh './mvnw jacoco:report'
                        } else {
                            bat 'mvnw.cmd jacoco:report'
                        }
                    }
                }
            }
            post {
                always {
                    jacoco(
                        execPattern: '**/target/jacoco.exec',
                        classPattern: '**/target/classes',
                        sourcePattern: '**/src/main/java',
                        exclusionPattern: '**/config/*,**/dto/*,**/model/*,**/exception/*'
                    )
                }
            }
        }

        stage('Docker Build') {
            when {
                branch 'main'
                expression { env.BRANCH_NAME == 'main' || env.BRANCH_NAME == 'develop' }
            }
            steps {
                dir("${SERVICE_DIR}") {
                    echo '🐳 Building Docker image...'
                    script {
                        if (isUnix()) {
                            sh """
                                docker build \
                                    --build-arg VERSION=${VERSION} \
                                    --build-arg JAR_FILE=target/*.jar \
                                    -t ${DOCKER_IMAGE}:${VERSION} \
                                    -t ${DOCKER_IMAGE}:latest \
                                    .
                                
                                # Security scan for Docker image
                                docker scout quickview ${DOCKER_IMAGE}:${VERSION} || true
                                docker scout cves ${DOCKER_IMAGE}:${VERSION} || true
                            """
                        } else {
                            bat """
                                docker build \
                                    --build-arg VERSION=${VERSION} \
                                    -t ${DOCKER_IMAGE}:${VERSION} \
                                    -t ${DOCKER_IMAGE}:latest \
                                    .
                            """
                        }
                    }
                }
            }
        }

        stage('Test Docker Image') {
            when { branch 'main' }
            steps {
                script {
                    def testContainer = "payment-service-test-${env.BUILD_NUMBER}"
                    sh """
                        docker run -d \
                            --name ${testContainer} \
                            -p 8080:8080 \
                            -e SPRING_PROFILES_ACTIVE=docker-test \
                            -e SPRING_DATASOURCE_URL=jdbc:h2:mem:testdb \
                            -e EUREKA_CLIENT_ENABLED=false \
                            -e APP_SECURITY_ENABLED=false \
                            ${DOCKER_IMAGE}:${VERSION}
                        
                        sleep 30
                        
                        # Health check
                        curl -fsS http://localhost:8080/actuator/health
                        curl -fsS http://localhost:8080/v3/api-docs
                        
                        # Cleanup
                        docker rm -f ${testContainer}
                    """
                }
            }
        }

        stage('Push to Registry') {
            when { 
                branch 'main'
                expression { env.DOCKER_REGISTRY_CREDENTIALS != null }
            }
            steps {
                echo '📤 Pushing Docker image to registry...'
                script {
                    withCredentials([string(credentialsId: 'docker-hub-token', variable: 'DOCKER_TOKEN')]) {
                        sh """
                            echo ${DOCKER_TOKEN} | docker login -u neuroguard --password-stdin
                            docker push ${DOCKER_IMAGE}:${VERSION}
                            docker push ${DOCKER_IMAGE}:latest
                        """
                    }
                }
            }
        }

        stage('Image Info') {
            steps {
                echo '📋 Docker Image Information:'
                script {
                    sh """
                        echo "Image: ${DOCKER_IMAGE}:${VERSION}"
                        echo "Size: $(docker images ${DOCKER_IMAGE}:${VERSION} --format '{{.Size}}')"
                        echo "Created: $(docker inspect ${DOCKER_IMAGE}:${VERSION} --format '{{.Created}}')"
                    """
                }
            }
        }
    }

    post {
        always {
            echo '🧹 Cleaning up...'
            script {
                // Cleanup test containers
                sh '''
                    docker rm -f payment-service-test-${BUILD_NUMBER} || true
                    docker rm -f ${TEST_DB_CONTAINER} || true
                    docker system prune -f || true
                '''
            }
        }
        success {
            emailext (
                subject: "✅ Pipeline SUCCESS: ${env.JOB_NAME} - ${env.BUILD_NUMBER}",
                body: """
                    Pipeline completed successfully!
                    
                    Job: ${env.JOB_NAME}
                    Build: ${env.BUILD_NUMBER}
                    Version: ${env.VERSION}
                    Image: ${env.DOCKER_IMAGE}:${env.VERSION}
                    Duration: ${env.BUILD_DURATION}
                    URL: ${env.BUILD_URL}
                """,
                to: 'team@neuroguard.com'
            )
            
            // Trigger CD pipeline only on main branch
            script {
                if (env.BRANCH_NAME == 'main') {
                    build job: 'payment-service-deploy',
                          wait: false,
                          parameters: [
                              string(name: 'VERSION', value: env.VERSION),
                              string(name: 'UPSTREAM_BUILD', value: env.BUILD_NUMBER)
                          ]
                }
            }
        }
        failure {
            emailext (
                subject: "❌ Pipeline FAILED: ${env.JOB_NAME} - ${env.BUILD_NUMBER}",
                body: """
                    Pipeline failed! Please check logs.
                    
                    Job: ${env.JOB_NAME}
                    Build: ${env.BUILD_NUMBER}
                    Failed Stage: ${env.STAGE_NAME}
                    URL: ${env.BUILD_URL}
                    
                    Check console output for details.
                """,
                to: 'team@neuroguard.com'
            )
        }
        unstable {
            echo '⚠️ Pipeline is unstable - tests may have failed but build succeeded'
        }
    }
}