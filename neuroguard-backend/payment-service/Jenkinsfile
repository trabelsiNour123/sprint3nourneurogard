pipeline {
    agent any

    environment {
        DOCKER_IMAGE = "neuroguard/payment-service"
        VERSION = "1.0.${env.BUILD_NUMBER}"
    }

    stages {

        stage('📦 Checkout') {
            steps {
                echo 'Récupération du code...'
                checkout scm
            }
        }

        stage('🏗️ Build & Install') {
            steps {
                dir('neuroguard-backend/payment-service') {
                    echo 'Compilation...'
                    sh './mvnw clean install -DskipTests'
                }
            }
        }

        stage('🧪 Tests') {
            steps {
                dir('neuroguard-backend/payment-service') {
                    echo 'Tests...'
                    sh './mvnw test'
                }
            }
            post {
                always {
                    junit 'neuroguard-backend/payment-service/target/surefire-reports/*.xml'
                }
            }
        }

        stage('🐳 Docker Build') {
            steps {
                dir('neuroguard-backend/payment-service') {
                    sh "docker build -t ${DOCKER_IMAGE}:${VERSION} ."
                    sh "docker tag ${DOCKER_IMAGE}:${VERSION} ${DOCKER_IMAGE}:latest"
                }
            }
        }

        stage('🚀 Status') {
            steps {
                sh "docker images | grep ${DOCKER_IMAGE}"
            }
        }
    }

    post {
        success {
            echo '✅ Pipeline OK'
        }
        failure {
            echo '❌ Erreur pipeline'
        }
    }
}