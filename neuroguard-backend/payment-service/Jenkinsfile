pipeline {
    agent any

    environment {
        SERVICE_DIR = 'neuroguard-backend/payment-service'
        DOCKER_IMAGE = 'neuroguard/payment-service'
        VERSION = "1.0.${env.BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                echo 'Checking out source code...'
                checkout scm
            }
        }

        stage('Build') {
            steps {
                dir("${SERVICE_DIR}") {
                    echo 'Building payment-service...'
                    script {
                        if (isUnix()) {
                            sh 'mvn clean install -DskipTests'
                        } else {
                            bat 'mvn clean install -DskipTests'
                        }
                    }
                }
            }
        }

        stage('Test') {
            steps {
                dir("${SERVICE_DIR}") {
                    echo 'Running tests...'
                    script {
                        if (isUnix()) {
                            sh 'mvn test'
                        } else {
                            bat 'mvn test'
                        }
                    }
                }
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: "${SERVICE_DIR}/target/surefire-reports/*.xml"
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir("${SERVICE_DIR}") {
                    script {
                        if (isUnix()) {
                            sh "docker build -t ${DOCKER_IMAGE}:${VERSION} ."
                            sh "docker tag ${DOCKER_IMAGE}:${VERSION} ${DOCKER_IMAGE}:latest"
                        } else {
                            bat "docker build -t ${DOCKER_IMAGE}:${VERSION} ."
                            bat "docker tag ${DOCKER_IMAGE}:${VERSION} ${DOCKER_IMAGE}:latest"
                        }
                    }
                }
            }
        }

        stage('Image Status') {
            steps {
                script {
                    if (isUnix()) {
                        sh "docker images ${DOCKER_IMAGE}"
                    } else {
                        bat "docker images ${DOCKER_IMAGE}"
                    }
                }
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully.'
        }
        failure {
            echo 'Pipeline failed.'
        }
    }
}
