pipeline {
    agent any

    // Using the project's Maven Wrapper (`./mvnw`) and the system Java installed on the agent.
    // Remove `tools` requirement so the pipeline won't fail when named tool installations
    // (like 'JDK17' or 'Maven3') are not configured in the Jenkins controller.

    environment {
        SERVICE_DIR = 'neuroguard-backend/payment-service'
        DOCKER_IMAGE = 'neuroguard/payment-service'
        VERSION = "1.0.${env.BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build & Test') {
            steps {
                dir("${SERVICE_DIR}") {
                    // ensure mvnw is executable and run in one shell so env exports apply
                    sh '''#!/bin/sh
                    chmod +x mvnw
                    # try to detect a suitable JAVA_HOME from the agent's java
                    if [ -x "$(command -v java)" ]; then
                      JAVA_BIN=$(command -v java)
                      JAVA_HOME=$(dirname $(dirname $(readlink -f "$JAVA_BIN"))) || true
                      echo "Detected JAVA_HOME=${JAVA_HOME}"
                      export JAVA_HOME
                      export PATH="$JAVA_HOME/bin:$PATH"
                    else
                      echo "java not found on PATH; mvnw will use default java in shell"
                    fi
                    # remove -Ptest (profile missing) and run tests with test profile as spring property
                    ./mvnw clean test -Dspring.profiles.active=test
                    '''
                }
            }
            post {
                always {
                    junit '**/target/surefire-reports/*.xml'
                }
            }
        }

        stage('Package') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh './mvnw package -DskipTests'
                }
            }
            post {
                success {
                    archiveArtifacts "${SERVICE_DIR}/target/*.jar"
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir("${SERVICE_DIR}") {
                    sh "docker build -t ${DOCKER_IMAGE}:${VERSION} ."
                    sh "docker tag ${DOCKER_IMAGE}:${VERSION} ${DOCKER_IMAGE}:latest"
                }
            }
        }
    }

    post {
        always {
            // Avoid failing if Docker is not available on the agent (e.g., no docker socket).
            sh 'if docker info >/dev/null 2>&1; then docker image prune -f; else echo "docker not available"; fi || true'
        }
        success {
            echo "Pipeline SUCCESS: ${env.JOB_NAME} - ${env.BUILD_NUMBER}"
        }
        failure {
            echo "Pipeline FAILED: ${env.JOB_NAME} - ${env.BUILD_NUMBER}"
        }
    }
}