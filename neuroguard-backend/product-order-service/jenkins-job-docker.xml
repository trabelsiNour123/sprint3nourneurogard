<?xml version='1.1' encoding='UTF-8'?>
<flow-definition plugin="workflow-job@2.52">
  <description>Build and push Docker image for product-order-service using Jenkinsfile.docker</description>
  <keepDependencies>false</keepDependencies>
  <properties/>
  <definition class="org.jenkinsci.plugins.workflow.cps.CpsScmFlowDefinition" plugin="workflow-cps@2.1122">
    <scm class="hudson.plugins.git.GitSCM" plugin="git@4.15.0">
      <configVersion>2</configVersion>
      <userRemoteConfigs>
        <hudson.plugins.git.UserRemoteConfig>
          <url>https://github.com/trabelsiNour123/sprint3nourneurogard.git</url>
        </hudson.plugins.git.UserRemoteConfig>
      </userRemoteConfigs>
      <branches>
        <hudson.plugins.git.BranchSpec>
          <name>*/main</name>
        </hudson.plugins.git.BranchSpec>
      </branches>
      <doGenerateSubmoduleConfigurations>false</doGenerateSubmoduleConfigurations>
      <submoduleCfg class="list"/>
      <extensions/>
    </scm>
    <scriptPath>neuroguard-backend/product-order-service/Jenkinsfile.docker</scriptPath>
  </definition>
  <triggers/>
  <disabled>false</disabled>
</flow-definition>
