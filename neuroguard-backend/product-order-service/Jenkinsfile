pipeline {
    agent any

    parameters {
        booleanParam(name: 'USE_DOCKER_AGENT', defaultValue: false, description: 'Run Docker build on a docker-labeled agent')
        booleanParam(name: 'SKIP_DOCKER_BUILD', defaultValue: false, description: 'Skip local docker build (useful when building/pushing from separate job)')
        booleanParam(name: 'TRIGGER_DOCKER_JOB', defaultValue: false, description: 'Trigger separate Docker build/push job')
        string(name: 'DOCKER_JOB_NAME', defaultValue: 'product-order-service-docker', description: 'Name of downstream Jenkins job to build/push Docker image')
        string(name: 'DOCKER_REGISTRY', defaultValue: '', description: 'Optional registry host (e.g. registry.example.com)')
        string(name: 'DOCKER_CREDENTIALS_ID', defaultValue: '', description: 'Credentials id for Docker registry (optional)')
    }

    environment {
        // Nom de l'image Docker
        DOCKER_IMAGE = "neuroguard/product-order-service"
        // Version (utilise le numéro de build Jenkins)
        VERSION = "1.0.${env.BUILD_NUMBER}"
    }

    stages {
        stage('📦 Checkout') {
            steps {
                echo 'Récupération du code...'
            }
        }

        stage('🏗️ Build & Install') {
            steps {
                dir('neuroguard-backend/product-order-service') {
                    echo 'Compilation et installation des dépendances...'
                    // use the project's Maven Wrapper when available
                                        sh '''#!/bin/sh
                                        if [ -f ./mvnw ]; then
                                            chmod +x ./mvnw || true
                                            ./mvnw clean install -DskipTests
                                        elif [ -f ../mvnw ]; then
                                            chmod +x ../mvnw || true
                                            ../mvnw clean install -DskipTests
                                        else
                                            mvn clean install -DskipTests
                                        fi
                                        '''
                }
            }
        }

        stage('🧪 Execution des Tests') {
            steps {
                                dir('neuroguard-backend/product-order-service') {
                                        echo 'Lancement des tests unitaires...'
                                        sh '''#!/bin/sh
                                        if [ -f ./mvnw ]; then
                                            chmod +x ./mvnw || true
                                            ./mvnw test
                                        elif [ -f ../mvnw ]; then
                                            chmod +x ../mvnw || true
                                            ../mvnw test
                                        else
                                            mvn test
                                        fi
                                        '''
                                }
            }
            post {
                always {
                    // Archive les rapports de tests pour les voir dans Jenkins
                    junit 'neuroguard-backend/product-order-service/target/surefire-reports/*.xml'
                }
            }
        }

        stage('🔁 Trigger Docker Job') {
            when {
                expression { return params.TRIGGER_DOCKER_JOB }
            }
            steps {
                script {
                    echo "Triggering downstream Docker job: ${params.DOCKER_JOB_NAME}"
                    build job: params.DOCKER_JOB_NAME, wait: false, parameters: [
                        string(name: 'DOCKER_IMAGE', value: env.DOCKER_IMAGE),
                        string(name: 'VERSION', value: env.VERSION),
                        string(name: 'DOCKER_REGISTRY', value: params.DOCKER_REGISTRY ?: ''),
                        string(name: 'DOCKER_CREDENTIALS_ID', value: params.DOCKER_CREDENTIALS_ID ?: '')
                    ]
                }
            }
        }

        stage('🐳 Build Image Docker (docker agent)') {
            when {
                expression { return params.USE_DOCKER_AGENT }
            }
            agent { label 'docker' }
            steps {
                dir('neuroguard-backend/product-order-service') {
                    echo "Building Docker image on docker-capable agent: ${DOCKER_IMAGE}:${VERSION}"
                    sh '''#!/bin/sh
                    docker version
                    docker build -t ${DOCKER_IMAGE}:${VERSION} .
                    docker tag ${DOCKER_IMAGE}:${VERSION} ${DOCKER_IMAGE}:latest
                    '''
                }
            }
            post {
                unsuccessful {
                    echo 'Docker agent stage failed — continuing pipeline.'
                }
            }
        }

        stage('🐳 Build Image Docker (fallback)') {
            when {
                expression { return !params.USE_DOCKER_AGENT && !params.SKIP_DOCKER_BUILD }
            }
            steps {
                dir('neuroguard-backend/product-order-service') {
                    echo "Construction de l'image Docker ${DOCKER_IMAGE}:${VERSION} (local fallback)..."
                    // If docker socket not available on agent, skip the docker build instead of failing the whole pipeline
                    sh '''#!/bin/sh
                    if docker version >/dev/null 2>&1; then
                      docker build -t ${DOCKER_IMAGE}:${VERSION} .
                      docker tag ${DOCKER_IMAGE}:${VERSION} ${DOCKER_IMAGE}:latest
                    else
                      echo "Docker not available on this agent, skipping image build."
                    fi
                    '''
                }
            }
            post {
                unsuccessful {
                    echo 'Docker fallback stage failed — continuing pipeline without failing overall build.'
                }
            }
        }

        stage('🚀 Status Image') {
            steps {
                echo "Image disponible localement : ${DOCKER_IMAGE}:${VERSION}"
                sh "docker images | grep ${DOCKER_IMAGE}"
            }
        }
    }

    post {
        success {
            echo '✅ Pipeline terminée avec succès !'
        }
        failure {
            echo '❌ Échec de la pipeline. Vérifiez les logs.'
        }
    }
}
